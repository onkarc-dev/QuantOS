# QuantOS API Dockerfile
# Render-safe backend deployment
# Builds required C++ backtest and live paper engines.

FROM ubuntu:22.04 AS cpp_builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    pkg-config \
    libssl-dev \
    zlib1g-dev \
    libwebsockets-dev \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY CMakeLists.txt .
COPY cpp_engine/ ./cpp_engine/
COPY proto/ ./proto/

RUN cmake -S . -B build -DCMAKE_BUILD_TYPE=Release \
    && cmake --build build --target prism_backtest -- -j$(nproc) \
    && cmake --build build --target prism_live_paper_trading -- -j$(nproc) \
    && test -x /build/build/prism_backtest \
    && test -x /build/build/prism_live_paper_trading

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PORT=8000

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    libgomp1 \
    libssl3 \
    zlib1g \
    libwebsockets16 \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY apps/api/requirements.txt .

RUN pip3 install --no-cache-dir --upgrade pip setuptools wheel \
    && pip3 install --no-cache-dir -r requirements.txt \
    && pip3 install --no-cache-dir psycopg2-binary rq redis python-dotenv

COPY apps/api/ ./apps/api/
COPY config/ ./config/
COPY configs/ ./configs/
COPY data/ ./data/
COPY scripts/ ./scripts/

RUN mkdir -p /app/build/Release /app/outputs

COPY --from=cpp_builder /build/build/prism_backtest /app/build/Release/prism_backtest
COPY --from=cpp_builder /build/build/prism_live_paper_trading /app/build/Release/prism_live_paper_trading

RUN chmod +x /app/build/Release/prism_backtest /app/build/Release/prism_live_paper_trading \
    && test -x /app/build/Release/prism_backtest \
    && test -x /app/build/Release/prism_live_paper_trading

ENV OUTPUTS_ROOT=/app/outputs
ENV ENGINE_BINARY_PATH=/app/build/Release/prism_backtest
ENV LIVE_PAPER_BINARY_PATH=/app/build/Release/prism_live_paper_trading
ENV PYTHONPATH=/app/apps/api

WORKDIR /app/apps/api

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]

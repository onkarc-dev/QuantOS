ENV=development
PRISMFLOW_SECRET_KEY=change-this-for-dev-and-use-a-long-random-secret-in-production
DATABASE_PATH=prismflow.db
CORS_ORIGINS=http://localhost:3000
OUTPUTS_ROOT=outputs
LOG_FILE=outputs/quantos_api.log

# QuantOS environment
ENV=production

# Database
DATABASE_URL=sqlite:///./prismflow.db
# For Docker/PostgreSQL use docker-compose defaults or:
# DATABASE_URL=postgresql://quantos:strong-password@postgres:5432/quantos
POSTGRES_PASSWORD=replace-with-strong-password

# Auth / JWT
PRISMFLOW_SECRET_KEY=replace-with-64-char-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TTL_SECONDS=2592000
SESSION_TTL_SECONDS=900

# OTP email delivery. Public production should keep EMAIL_OTP_DEV_RETURN=false.
EMAIL_OTP_DEV_RETURN=false
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@yourdomain.com
SMTP_TLS=true

# Frontend/API URLs
NEXT_PUBLIC_API_BASE=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENFORCE_HTTPS=false

# Redis / queue
REDIS_URL=redis://redis:6379/0

# Engine / outputs
OUTPUTS_ROOT=outputs
ENGINE_BINARY_PATH=build/Release/prism_backtest.exe
LIVE_PAPER_BINARY_PATH=build/Release/prism_live_paper_trading.exe
LOG_FILE=apps/api/quantos_api.log

# Product safety
SAFE_MODE=true
REAL_MONEY_ENABLED=false
BROKER_INTEGRATION_ENABLED=false

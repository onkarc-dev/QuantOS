# QuantOS root environment example. Copy to .env for local development only.
ENV=development
PRISMFLOW_SECRET_KEY=change-this-to-a-stable-64-character-random-secret-for-shared-dev
DATABASE_PATH=prismflow.db
# DATABASE_URL=postgresql://user:password@host:5432/quantos
REDIS_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENFORCE_HTTPS=false
API_HOST=127.0.0.1
API_PORT=8000
OUTPUTS_ROOT=outputs
LOG_FILE=outputs/quantos_api.log
ENGINE_BINARY_PATH=build/Release/prism_backtest
LIVE_PAPER_BINARY_PATH=build/Release/prism_live_paper_trading
# Optional AI explainer; app falls back when unset.
OPENAI_API_KEY=

# Frontend (Vercel)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Local engine; keep exchange/premium credentials on user machine only.
QUANTOS_API_URL=http://127.0.0.1:8000
QUANTOS_ENGINE_MODE=paper
QUANTOS_ENGINE_EXCHANGE=binance
QUANTOS_ENGINE_SOURCE=BTCUSDT
BINANCE_API_KEY=
BINANCE_API_SECRET=
CUSTOM_WS_URL=
CUSTOM_WS_AUTH_HEADER=

# Basic per-IP API rate limit. Set 0 to disable in trusted local tests.
RATE_LIMIT_PER_MINUTE=120
